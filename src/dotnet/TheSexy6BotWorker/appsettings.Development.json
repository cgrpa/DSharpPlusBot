{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "TavilyApi": {
    "Endpoint": "https://api.tavily.com",
    "TimeoutSeconds": 30,
    "MaxRetries": 2,
    "BaseDelayMilliseconds": 250,
    "MaxDelayMilliseconds": 4000
  },
  "ImageGeneration": {
    "Enabled": true,
    "ManualEnabled": true,
    "AutoEnabled": true,
    "OpenRouterEndpoint": "https://openrouter.ai/api/v1/",
    "DefaultModelId": "black-forest-labs/flux.2-klein-4b",
    "FallbackModelId": "bytedance-seed/seedream-4.5",
    "BlobContainerName": "generated-images",
    "QuotaTableName": "imagequota",
    "DedupeTableName": "imagededupe",
    "MetadataTableName": "imagemetadata",
    "StorageConnectionString": "UseDevelopmentStorage=true",
    "DailyQuotaLimit": 10,
    "MaxDecodedBytes": 26214400,
    "OpenRouterTimeoutSeconds": 120,
    "AspectRatio": "1:1",
    "ImageSize": "1K"
  }
}
