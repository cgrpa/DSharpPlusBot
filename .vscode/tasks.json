{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/TheSexy6BotWorker/TheSexy6BotWorker.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
        {
            "label": "docker-build-sexy6botworker",
            "type": "shell",
            "command": "docker",
            "args": [
              "build",
              "-t",
              "sexy6botworker:dev",
              "."
            ],
            "options": {
              "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
              "kind": "build",
              "isDefault": true
            }
          },
          {
            "label": "docker-run-sexy6botworker",
            "type": "shell",
            "command": "docker",
            "args": [
              "run",
              "--rm",
              "--name",
              "sexy6botworker-dev",
              "--env-file",
              ".env",
              "sexy6botworker:dev"
            ],
            "options": {
              "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": "docker-build-sexy6botworker",
            "isBackground": false
          }
    ]
}